# SiliconFlow API (Required - primary LLM provider)
SILICONFLOW_API_KEY=your_key_here

# MinerU API (Required for remote mode - PDF to Markdown conversion)
MINERU_API_KEY=your_key_here

# MinerU Local Server URL (for local mode)
MINERU_LOCAL_BASE_URL=http://localhost:7860

# Google Gemini API (Optional - alternative LLM provider)
GOOGLE_API_KEY=your_key_here

# VectorEngine API (Optional - alternative LLM provider)
VECTORENGINE_API_KEY=your_key_here

# LLM Stage Providers (optional, defaults in settings.yaml)
# CHUNKING_PROVIDER=siliconflow
# PEELING_PROVIDER=siliconflow
# SKILL_ENGINE_PROVIDER=siliconflow

# LLM Model Overrides (optional, defaults in settings.yaml)
# CHUNKING_MODEL=deepseek-ai/DeepSeek-R1
# PEELING_MODEL=deepseek-ai/DeepSeek-V3
# SKILL_ENGINE_MODEL=THUDM/GLM-4-9B-0414

# MinerU Configuration
# MINERU_API_MODE=remote
# MINERU_LANGUAGE=ch

# PDF Processing
# PDF_PAGE_LIMIT=200
# CHUNK_MERGE_THRESHOLD=5000
# CHUNK_MIN_THRESHOLD=1000

# Request Control
# REQUEST_INTERVAL=1.0
